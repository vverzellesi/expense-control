generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH.JS MODELS
// ==========================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  transactions      Transaction[]
  categories        Category[]
  recurringExpenses RecurringExpense[]
  installments      Installment[]
  origins           Origin[]
  budgets           Budget[]
  categoryRules     CategoryRule[]
  categoryTags      CategoryTag[]
  settings          Settings[]
  savingsHistories  SavingsHistory[]

  // Investment models
  investmentCategories InvestmentCategory[]
  investments          Investment[]
  investmentSnapshots  InvestmentSnapshot[]

  // Bill payment models
  billPayments BillPayment[]

  // Simulation models
  simulations Simulation[]

  // Shared space models
  createdSpaces       Space[]       @relation("CreatedSpaces")
  spaceMemberships    SpaceMember[]
  createdTransactions Transaction[] @relation("CreatedTransactions")

  // Telegram integration
  telegramLink           TelegramLink?
  telegramLinkTokens     TelegramLinkToken[]
  telegramPendingImports TelegramPendingImport[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

// ==========================================
// DOMAIN MODELS
// ==========================================

model Transaction {
  id                 String            @id @default(cuid())
  description        String
  amount             Float
  date               DateTime
  type               String // "INCOME" or "EXPENSE"
  origin             String
  categoryId         String?
  category           Category?         @relation(fields: [categoryId], references: [id])
  isFixed            Boolean           @default(false)
  isInstallment      Boolean           @default(false)
  installmentId      String?
  installment        Installment?      @relation(fields: [installmentId], references: [id])
  currentInstallment Int?
  totalInstallments  Int? // Total de parcelas (para transacoes avulsas sem grupo)
  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id])
  tags               String? // JSON array: '["trabalho", "viagem"]'
  categoryTagId      String?
  categoryTag        CategoryTag?      @relation(fields: [categoryTagId], references: [id], onDelete: SetNull)
  deletedAt          DateTime? // Soft delete - null means active
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space fields
  spaceId         String?
  space           Space?  @relation("SpaceTransactions", fields: [spaceId], references: [id], onDelete: SetNull)
  isPrivate       Boolean @default(false)
  createdByUserId String?
  createdByUser   User?   @relation("CreatedTransactions", fields: [createdByUserId], references: [id])

  // Investment transaction link (reverse relation)
  investmentTransaction InvestmentTransaction?

  @@index([userId])
  @@index([userId, date])
  @@index([userId, type, deletedAt])
  @@index([userId, deletedAt, date])
  @@index([userId, isFixed, deletedAt])
  @@index([userId, isInstallment, deletedAt])
  @@index([spaceId])
  @@index([createdByUserId])
}

model RecurringExpense {
  id            String        @id @default(cuid())
  description   String
  defaultAmount Float // Valor padrao
  dayOfMonth    Int // Dia do mes para gerar (1-31)
  type          String // "INCOME" or "EXPENSE"
  origin        String
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  isActive      Boolean       @default(true)
  autoGenerate  Boolean       @default(true) // false = aguarda importacao e vincula
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceRecurring", fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id                String             @id @default(cuid())
  name              String
  color             String
  icon              String?
  transactions      Transaction[]
  budgets           Budget[]
  categoryRules     CategoryRule[]
  categoryTags      CategoryTag[]
  recurringExpenses RecurringExpense[]
  simulations       Simulation[]

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceCategories", fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
  @@unique([name, spaceId])
  @@index([userId])
}

model Installment {
  id                String        @id @default(cuid())
  description       String
  totalAmount       Float
  totalInstallments Int
  installmentAmount Float
  startDate         DateTime
  origin            String
  transactions      Transaction[]

  // Bill payment back-reference (for financed bills)
  billPayment BillPayment?

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceInstallments", fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Origin {
  id   String @id @default(cuid())
  name String

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceOrigins", fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
  @@unique([name, spaceId])
  @@index([userId])
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Float
  isActive   Boolean  @default(true)

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceBudgets", fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId])
  @@unique([categoryId, spaceId])
  @@index([userId])
  @@index([userId, isActive])
}

model CategoryRule {
  id         String   @id @default(cuid())
  keyword    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceRules", fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([keyword, categoryId, userId])
  @@unique([keyword, categoryId, spaceId])
  @@index([userId])
}

model CategoryTag {
  id           String        @id @default(cuid())
  name         String
  keywords     String // Comma-separated: "shell,ipiranga,posto"
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceTags", fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId, userId])
  @@unique([name, categoryId, spaceId])
  @@index([userId])
  @@index([categoryId])
}

model Settings {
  id        String   @id @default(cuid())
  key       String
  value     String
  updatedAt DateTime @updatedAt

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@index([userId])
}

model SavingsHistory {
  id         String   @id @default(cuid())
  month      Int
  year       Int
  goal       Float
  actual     Float
  isAchieved Boolean
  percentage Float
  createdAt  DateTime @default(now())

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([month, year, userId])
  @@index([userId])
}

// ==========================================
// INVESTMENT MODELS
// ==========================================

model InvestmentCategory {
  id        String  @id @default(cuid())
  name      String
  color     String // Hex color
  icon      String? // Lucide icon name
  isDefault Boolean @default(false)

  // User relationship (null for default categories)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceInvestmentCategories", fields: [spaceId], references: [id], onDelete: Cascade)

  investments Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, userId, spaceId])
  @@index([userId])
}

model Investment {
  id          String  @id @default(cuid())
  name        String
  description String?

  categoryId String
  category   InvestmentCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  currentValue   Float // Valor atual
  totalInvested  Float // Total aportado
  totalWithdrawn Float @default(0) // Total resgatado

  goalAmount Float? // Meta (opcional)
  broker     String? // Corretora/banco (opcional)

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Shared space
  spaceId String?
  space   Space?  @relation("SpaceInvestments", fields: [spaceId], references: [id], onDelete: Cascade)

  transactions InvestmentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
}

model InvestmentTransaction {
  id String @id @default(cuid())

  investmentId String
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  type   String // "DEPOSIT" | "WITHDRAWAL"
  amount Float
  date   DateTime
  notes  String?

  // Link with cash flow Transaction
  linkedTransactionId String?      @unique
  linkedTransaction   Transaction? @relation(fields: [linkedTransactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([investmentId])
  @@index([linkedTransactionId])
}

model InvestmentSnapshot {
  id String @id @default(cuid())

  month Int // 1-12
  year  Int

  totalValue     Float // Soma de todos currentValue
  totalInvested  Float // Soma de todos totalInvested
  totalWithdrawn Float // Soma de todos totalWithdrawn

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([month, year, userId])
  @@index([userId])
}

// ==========================================
// BILL PAYMENT MODELS
// ==========================================

model BillPayment {
  id                     String       @id @default(cuid())
  billMonth              Int
  billYear               Int
  origin                 String
  totalBillAmount        Float
  amountPaid             Float
  amountCarried          Float
  paymentType            String // "PARTIAL" or "FINANCED"
  installmentId          String?      @unique
  installment            Installment? @relation(fields: [installmentId], references: [id])
  interestRate           Float?
  interestAmount         Float?
  entryTransactionId     String?
  carryoverTransactionId String?
  linkedTransactionId    String?
  userId                 String
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([userId])
  @@index([billMonth, billYear, origin])
}

// ==========================================
// SIMULATION MODELS
// ==========================================

model Simulation {
  id                String    @id @default(cuid())
  description       String
  totalAmount       Float
  totalInstallments Int       @default(1)
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// SHARED SPACE MODELS
// ==========================================

enum SpaceRole {
  ADMIN
  MEMBER
  LIMITED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Space {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  creator   User     @relation("CreatedSpaces", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              SpaceMember[]
  invites              SpaceInvite[]
  transactions         Transaction[]        @relation("SpaceTransactions")
  categories           Category[]           @relation("SpaceCategories")
  origins              Origin[]             @relation("SpaceOrigins")
  budgets              Budget[]             @relation("SpaceBudgets")
  rules                CategoryRule[]       @relation("SpaceRules")
  tags                 CategoryTag[]        @relation("SpaceTags")
  recurring            RecurringExpense[]   @relation("SpaceRecurring")
  installments         Installment[]        @relation("SpaceInstallments")
  investments          Investment[]         @relation("SpaceInvestments")
  investmentCategories InvestmentCategory[] @relation("SpaceInvestmentCategories")
}

model SpaceMember {
  id       String    @id @default(cuid())
  spaceId  String
  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     SpaceRole
  joinedAt DateTime  @default(now())

  @@unique([spaceId, userId])
}

model SpaceInvite {
  id        String       @id @default(cuid())
  spaceId   String
  space     Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  email     String?
  code      String       @unique
  role      SpaceRole
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@index([code])
  @@index([email])
}

// ==========================================
// TELEGRAM INTEGRATION
// ==========================================

model TelegramLink {
  id       String   @id @default(cuid())
  userId   String   @unique
  chatId   String   @unique
  linkedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model TelegramPendingImport {
  id        String   @id @default(cuid())
  userId    String
  chatId    String
  payload   String   // JSON array of transactions
  origin    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
