# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true

# Resend (Email)
# Get your API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxx"

# GitHub Integration (Bug Reports)
# Classic PAT with scopes: 'repo' (Issues + Contents API) and 'project' (Project Board v2)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=""

# PDF encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PDF_ENCRYPTION_KEY=

# Google Gemini API (opcional — sem ela o AI parser desliga e cai no fallback regex)
GEMINI_API_KEY=

# Quota mensal de calls de IA por usuário (default 5)
AI_MONTHLY_QUOTA=5
